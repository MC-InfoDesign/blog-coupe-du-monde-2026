# ─── Choisis UN des deux providers ───────────────────────────────────────────

# OPTION A — Groq (GRATUIT, sans carte bancaire)
# Inscription : https://console.groq.com → API Keys → Create API key
GROQ_API_KEY=gsk_...

# OPTION B — Anthropic Claude (payant, ~0.01€/article)
# Inscription : https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ─── NewsAPI (optionnel) ──────────────────────────────────────────────────────
# Sans cette clé, l'agent utilise des sujets prédéfinis (fonctionne quand même)
# Inscription gratuite : https://newsapi.org/register
# NEWS_API_KEY=
