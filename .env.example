# Copiez ce fichier en .env et renseignez vos clés
# cp .env.example .env

# Clé Anthropic (obligatoire pour générer des articles)
# Obtenez la vôtre sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Clé NewsAPI (optionnelle — sans elle, l'agent utilise des sujets de secours)
# Obtenez la vôtre sur https://newsapi.org/register (plan gratuit disponible)
NEWS_API_KEY=
